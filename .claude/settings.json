{
  "permissions": {
    "allow": [
      "Bash(npm run *)",
      "Bash(npm test*)",
      "Bash(npm install*)",
      "Bash(npm audit*)",
      "Bash(npx tsc*)",
      "Bash(npx eslint*)",
      "Bash(npx drizzle-kit*)",
      "Bash(npx tsx*)",
      "Bash(npx next*)",
      "Bash(npx playwright*)",
      "Bash(npx inngest-cli*)",
      "Bash(node scripts/*)",
      "Bash(agent-browser *)",
      "Bash(npx agent-browser*)",
      "Bash(git status*)",
      "Bash(git diff*)",
      "Bash(git log*)",
      "Bash(git show*)",
      "Bash(git branch*)",
      "Bash(git add *)",
      "Bash(ls*)",
      "Bash(wc*)",
      "Bash(grep*)",
      "Bash(jq*)"
    ],
    "deny": [
      "Read(.env)",
      "Read(.env.local)",
      "Read(.env.development)",
      "Read(.env.production)",
      "Read(./.data/**)"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/block-secrets.sh",
            "timeout": 10,
            "statusMessage": "Scanning for leaked secrets"
          },
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/lint-on-edit.sh",
            "timeout": 45,
            "async": true,
            "statusMessage": "Auto-fixing lint"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "echo \"Recent commits:\"; git log --oneline -5 2>/dev/null; echo \"Stack: Next.js 16 App Router + TS + Tailwind v4 + Drizzle (PGlite dev / Neon prod) + Clerk + Inngest. Read CLAUDE.md before large changes.\"",
            "timeout": 5
          }
        ]
      }
    ]
  }
}
