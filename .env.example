# -----------------------------------------------------------------------------
# Database
# -----------------------------------------------------------------------------
# Neon Postgres connection string. If unset, the app falls back to a local
# PGlite database persisted at .data/pglite (zero-config dev mode).
# DATABASE_URL=postgres://user:password@host/dbname?sslmode=require

# -----------------------------------------------------------------------------
# Auth / Clerk
# -----------------------------------------------------------------------------
# If unset, Clerk runs in "keyless" dev mode.
# NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_xxx
# CLERK_SECRET_KEY=sk_test_xxx

# -----------------------------------------------------------------------------
# Storage
# -----------------------------------------------------------------------------
# 'local' (default, filesystem under .data/) or 'r2' (Cloudflare R2 / S3-compatible)
# STORAGE_DRIVER=local
# R2_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com
# R2_ACCESS_KEY_ID=
# R2_SECRET_ACCESS_KEY=
# R2_BUCKET=

# -----------------------------------------------------------------------------
# LLM providers
# -----------------------------------------------------------------------------
# ANTHROPIC_API_KEY=
# If GOOGLE_API_KEY is unset, image generation falls back to a mock driver.
# GOOGLE_API_KEY=

# Model slots (defaults shown)
# MODEL_SEGMENT=claude-haiku-4-5
# MODEL_SYNTHESIS=claude-haiku-4-5
# MODEL_CHAT=claude-haiku-4-5
# MODEL_IMAGE=gemini-2.5-flash-image

# -----------------------------------------------------------------------------
# Stripe (billing) — placeholders
# -----------------------------------------------------------------------------
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=
# STRIPE_PRICE_ID=

# -----------------------------------------------------------------------------
# App
# -----------------------------------------------------------------------------
# APP_URL=http://localhost:3000
