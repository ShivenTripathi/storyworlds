# -----------------------------------------------------------------------------
# Database
# -----------------------------------------------------------------------------
# Neon Postgres connection string. If unset, the app falls back to a local
# PGlite database persisted at .data/pglite (zero-config dev mode).
# DATABASE_URL=postgres://user:password@host/dbname?sslmode=require

# -----------------------------------------------------------------------------
# Auth / Clerk
# -----------------------------------------------------------------------------
# If unset, Clerk runs in "keyless" dev mode.
# NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_xxx
# CLERK_SECRET_KEY=sk_test_xxx

# -----------------------------------------------------------------------------
# Storage
# -----------------------------------------------------------------------------
# 'local' (default, dev filesystem under .data/)
# 'db'    (ZERO-COST PROD DEFAULT — Neon/PGlite bytea column, served via
#          /api/files/[...key]; set STORAGE_DRIVER=db when deploying to
#          Vercel so prod stays card-free)
# 'r2'    (Cloudflare R2 / S3-compatible — REQUIRES A CARD, avoid unless the
#          zero-cost constraint has been explicitly relaxed)
# STORAGE_DRIVER=local
# R2_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com
# R2_ACCESS_KEY_ID=
# R2_SECRET_ACCESS_KEY=
# R2_BUCKET=

# -----------------------------------------------------------------------------
# LLM providers
# -----------------------------------------------------------------------------
# ANTHROPIC_API_KEY=
#
# ZERO-COST DEFAULT TEXT LLM PROVIDER: Google AI Studio's free tier
# (Gemini Flash / Flash-Lite — no card required). Get a free key at
# https://aistudio.google.com/apikey
# If GOOGLE_API_KEY is unset, any `gemini:`-prefixed model slot falls back
# to a deterministic MockDriver (dev stays keyless-friendly).
# GOOGLE_API_KEY=

# Model slots (defaults shown). Values may be provider-prefixed:
#   gemini:<model>     -> Google AI Studio (free tier, card-free)
#   anthropic:<model>  -> Anthropic (paid)
# A bare model name (no prefix) is treated as anthropic: for back-compat.
# Free-tier RPM is low (~15 RPM flash / ~30 RPM flash-lite) — keep pipeline
# concurrency low; the client backs off automatically on 429.
# MODEL_SEGMENT=gemini:gemini-2.5-flash-lite
# MODEL_SYNTHESIS=gemini:gemini-2.5-flash
# MODEL_CHAT=gemini:gemini-2.5-flash-lite
# MODEL_IMAGE=none

# -----------------------------------------------------------------------------
# Stripe (billing) — placeholders
# -----------------------------------------------------------------------------
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=
# STRIPE_PRICE_ID=

# -----------------------------------------------------------------------------
# App
# -----------------------------------------------------------------------------
# APP_URL=http://localhost:3000

# --- Jobs (Inngest) ---
# Local dev MUST set INNGEST_DEV=1 (SDK otherwise assumes cloud mode and requires a signing key).
# Run the local runner alongside: npx inngest-cli dev -u http://localhost:3000/api/inngest
INNGEST_DEV=1

# --- Platform / entitlements ---
# Comma-separated emails auto-promoted to admin on sign-in.
ADMIN_EMAILS=
# Daily limits per plan (also protect the Gemini free-tier quota).
FREE_UPLOADS_PER_DAY=2
FREE_CHAT_PER_DAY=20
READER_UPLOADS_PER_DAY=20
READER_CHAT_PER_DAY=500

# --- Billing (Stripe; dormant unless enabled — zero-cost constraint) ---
# Stripe test mode needs no payment card. Leave BILLING_ENABLED unset/false to run fully free.
BILLING_ENABLED=false
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_READER=
