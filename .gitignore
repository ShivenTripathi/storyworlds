# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# environment
.env
.env.*
!.env.example

# local dev data (pglite, uploaded files)
/.data/

# test fixtures (copyrighted material stays out of git)
caves_of_steel.pdf

# legacy build artifacts
frontend/node_modules
frontend/build
backend/__pycache__

# clerk configuration (can include secrets)
/.clerk/

# clerk keyless dev credentials
/.clerk/
